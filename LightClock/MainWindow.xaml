<Window
    x:Class="LightClock.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:LightClock"
    mc:Ignorable="d">

    <!--
        RootGrid is fully transparent so only clock text is rendered.
        PointerPressed starts the native window drag on left-button.
        ContextFlyout is the right-click settings / exit menu.
    -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          PointerPressed="RootGrid_PointerPressed">

        <Grid.ContextFlyout>
            <MenuFlyout>
                <ToggleMenuFlyoutItem x:Name="AlwaysOnTopItem"
                                      Text="Always on Top"
                                      IsChecked="True"
                                      Click="AlwaysOnTop_Click"/>
                <ToggleMenuFlyoutItem x:Name="ShowSecondsItem"
                                      Text="Show Seconds"
                                      IsChecked="False"
                                      Click="ShowSeconds_Click"/>
                <ToggleMenuFlyoutItem x:Name="Use24HourItem"
                                      Text="24-Hour Format"
                                      IsChecked="True"
                                      Click="Use24Hour_Click"/>
                <MenuFlyoutSubItem Text="Font">
                    <RadioMenuFlyoutItem x:Name="FontDefaultItem"
                                         GroupName="ClockFont"
                                         Text="Segoe UI Variable"
                                         IsChecked="True"
                                         Click="FontOption_Click"
                                         Tag="default"/>
                    <RadioMenuFlyoutItem x:Name="FontMonoItem"
                                         GroupName="ClockFont"
                                         Text="Consolas"
                                         Click="FontOption_Click"
                                         Tag="mono"/>
                    <RadioMenuFlyoutItem x:Name="FontSerifItem"
                                         GroupName="ClockFont"
                                         Text="Georgia"
                                         Click="FontOption_Click"
                                         Tag="serif"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Exit" Click="Exit_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8BB;"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">

            <!-- Date line: e.g. "Sunday, April 26" -->
            <TextBlock x:Name="DateText"
                       Text="Sunday, January 1"
                       FontFamily="Segoe UI Variable"
                       FontSize="17"
                       FontWeight="SemiLight"
                       Foreground="#CCF3FFFF"
                       HorizontalAlignment="Center"/>

            <!-- ── Time row: HH:MM  [AM/PM stacked above :SS] ── -->
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Large time digits -->
                <TextBlock x:Name="TimeText"
                           Grid.Column="0"
                           Text="12:00"
                           FontFamily="Segoe UI Variable Display"
                           FontSize="118"
                           FontWeight="SemiBold"
                           CharacterSpacing="-35"
                           Foreground="#CCF3FFFF"
                           VerticalAlignment="Center"/>

                <!-- AM/PM and seconds stacked to the right, baseline-aligned -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Margin="10,0,0,14"
                            Spacing="4">

                    <TextBlock x:Name="AmPmText"
                               Text="AM"
                               FontFamily="Segoe UI Variable"
                               FontSize="18"
                               FontWeight="Light"
                               Foreground="#AAE8F9FF"
                               HorizontalAlignment="Left"/>

                    <TextBlock x:Name="SecondsText"
                               Text=":00"
                               FontFamily="Segoe UI Variable"
                               FontSize="16"
                               FontWeight="Light"
                               Foreground="#88E8F9FF"
                               HorizontalAlignment="Left"/>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Grid>
</Window>
