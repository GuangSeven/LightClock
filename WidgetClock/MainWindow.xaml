<Window
    x:Class="WidgetClock.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:WidgetClock"
    mc:Ignorable="d">

    <!--
        RootGrid: transparent so the DesktopAcrylic system backdrop shows through.
        PointerPressed starts the native window drag on left-button.
        ContextFlyout is the right-click settings / exit menu.
    -->
    <Grid x:Name="RootGrid"
          Background="Transparent"
          PointerPressed="RootGrid_PointerPressed">

        <Grid.ContextFlyout>
            <MenuFlyout>
                <ToggleMenuFlyoutItem x:Name="AlwaysOnTopItem"
                                      Text="Always on Top"
                                      IsChecked="True"
                                      Click="AlwaysOnTop_Click"/>
                <ToggleMenuFlyoutItem x:Name="ShowSecondsItem"
                                      Text="Show Seconds"
                                      IsChecked="True"
                                      Click="ShowSeconds_Click"/>
                <ToggleMenuFlyoutItem x:Name="Use24HourItem"
                                      Text="24-Hour Format"
                                      IsChecked="False"
                                      Click="Use24Hour_Click"/>
                <MenuFlyoutSubItem Text="Font">
                    <RadioMenuFlyoutItem x:Name="FontDefaultItem"
                                         GroupName="ClockFont"
                                         Text="Segoe UI Variable"
                                         IsChecked="True"
                                         Click="FontOption_Click"
                                         Tag="default"/>
                    <RadioMenuFlyoutItem x:Name="FontMonoItem"
                                         GroupName="ClockFont"
                                         Text="Consolas"
                                         Click="FontOption_Click"
                                         Tag="mono"/>
                    <RadioMenuFlyoutItem x:Name="FontSerifItem"
                                         GroupName="ClockFont"
                                         Text="Georgia"
                                         Click="FontOption_Click"
                                         Tag="serif"/>
                </MenuFlyoutSubItem>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Exit" Click="Exit_Click">
                    <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8BB;"/>
                    </MenuFlyoutItem.Icon>
                </MenuFlyoutItem>
            </MenuFlyout>
        </Grid.ContextFlyout>

        <!--
            ClockBorder: the frosted-glass panel.
            The dark semi-transparent background layers over the acrylic backdrop,
            producing the macOS "dark glass" widget look.
        -->
        <Border x:Name="ClockBorder"
                CornerRadius="18"
                Padding="30,18,30,20">
            <Border.Background>
                <!-- #CC = 80 % opacity dark charcoal, matching macOS dark widget -->
                <SolidColorBrush Color="#CC1C1C1E"/>
            </Border.Background>

            <!-- Subtle inner border for depth -->
            <Border.BorderBrush>
                <SolidColorBrush Color="#28FFFFFF"/>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>0.5</Thickness>
            </Border.BorderThickness>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="6">

                <!-- ── Time row: HH:MM  [AM/PM stacked above :SS] ── -->
                <Grid HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Large time digits -->
                    <TextBlock x:Name="TimeText"
                               Grid.Column="0"
                               Text="12:00"
                               FontFamily="Segoe UI Variable Display"
                               FontSize="54"
                               FontWeight="Thin"
                               CharacterSpacing="-30"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <!-- AM/PM and seconds stacked to the right, baseline-aligned -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Margin="10,0,0,6"
                                Spacing="4">

                        <TextBlock x:Name="AmPmText"
                                   Text="AM"
                                   FontFamily="Segoe UI Variable"
                                   FontSize="15"
                                   FontWeight="Light"
                                   Foreground="#CCFFFFFF"
                                   HorizontalAlignment="Left"/>

                        <TextBlock x:Name="SecondsText"
                                   Text=":00"
                                   FontFamily="Segoe UI Variable"
                                   FontSize="13"
                                   FontWeight="Light"
                                   Foreground="#88FFFFFF"
                                   HorizontalAlignment="Left"/>
                    </StackPanel>
                </Grid>

                <!-- Thin horizontal rule between time and date -->
                <Rectangle Height="0.5"
                           Fill="#33FFFFFF"
                           HorizontalAlignment="Stretch"
                           Margin="0,2,0,2"/>

                <!-- Date line: e.g. "Sunday, April 26" -->
                <TextBlock x:Name="DateText"
                           Text="Sunday, January 1"
                           FontFamily="Segoe UI Variable"
                           FontSize="12"
                           FontWeight="Light"
                           CharacterSpacing="20"
                           Foreground="#99FFFFFF"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
